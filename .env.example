# --- Database (Turso / libsql) --------------------------------------------
# Omit both for local dev — the app falls back to a local SQLite file (local.db).
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# --- AI generation ---------------------------------------------------------
GOOGLE_AI_API_KEY=
REPLICATE_API_TOKEN=

# --- Auth (Better Auth + Google) ------------------------------------------
# Generate a strong secret, e.g. `openssl rand -base64 32`.
BETTER_AUTH_SECRET=
# Public base URL of the app (used for OAuth callbacks). Local dev default:
BETTER_AUTH_URL=http://localhost:3000

# Google OAuth credentials (Google Cloud Console → Credentials → OAuth client).
# Authorized redirect URI: <BETTER_AUTH_URL>/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Host voice (optional) -------------------------------------------------
# ElevenLabs TTS for host narration. Absence disables the feature gracefully.
ELEVENLABS_API_KEY=
ELEVENLABS_MODEL_ID=

# --- Moderation ------------------------------------------------------------
# Comma-separated admin emails granted access to /admin (report review,
# block/unblock). Leave empty to disable admin access entirely.
ADMIN_EMAILS=
